# Buildkite log management helper
#
# See https://buildkite.com/docs/pipelines/managing-log-output
#
# |source| me
#

base_dir="$(cd "$(dirname "$0")/.." && pwd)"
_() {
  if [[ $(pwd) = $base_dir ]]; then
    echo "--- $*" > /dev/stderr
  else
    echo "--- $* (wd: $(pwd))" > /dev/stderr
  fi
  "$@"
}
